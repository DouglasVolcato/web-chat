{{- $footerBrand := default .brand "Super Template" -}}
    <footer class="bg-body-tertiary border-top mt-auto py-4{{ if .appFooter }} app-footer{{ end }}">
      <div class="container d-flex flex-column flex-md-row justify-content-between align-items-center gap-3">
        <div class="d-flex align-items-center gap-3 justify-content-evenly flex-wrap">
          <div class="d-flex align-items-center gap-2 flex-wrap">
            <span class="badge bg-primary-subtle text-primary fw-semibold">Template</span>
            <span class="fw-bold text-primary">{{ $footerBrand }}</span>
          </div>
          <span class="text-secondary small">Base pronta para seu próximo projeto.</span>
        </div>
        <div class="d-flex gap-3 small align-items-center justify-content-evenly flex-wrap">
          <a class="text-secondary text-decoration-none" href="{{ url "/termos" }}">Termos de uso</a>
          <a class="text-secondary text-decoration-none" href="{{ url "/privacidade" }}">Política de privacidade</a>
          <span class="text-secondary">Bootstrap + HTMX + Go + Postgres</span>
        </div>
      </div>
    </footer>
