<div class="chat-message is-user">
  <div class="chat-bubble">
    <div class="chat-text" style="white-space: pre-wrap;">{{ .UserMessage.Message }}</div>
  </div>
</div>

<div id="aiResponsePlaceholder" 
     hx-get='{{ url (printf "/app/chat/%s/ai-response" .ChatID) }}' 
     hx-trigger="load" 
     hx-swap="outerHTML"
     class="typing-indicator-wrap">
  <div class="typing-indicator">
    <span></span><span></span><span></span>
    <small class="text-muted" style="font-size: 0.7rem;">IA digita...</small>
  </div>
</div>
