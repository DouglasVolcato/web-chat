{{- $version := default .cacheVersion "1" -}}
    <script src="{{ url "/js/bootstrap.bundle.min.js" }}?v={{ $version }}" defer></script>
    <script src="{{ url "/js/htmx.min.js" }}?v={{ $version }}" defer></script>
    <script>
      (() => {
        const storageKey = "template-theme";
        const root = document.documentElement;

        const applyTheme = (theme) => {
          root.setAttribute("data-bs-theme", theme);
          try {
            localStorage.setItem(storageKey, theme);
          } catch (error) {
            // ignore storage failures
          }

          const label = theme === "dark" ? "Tema escuro" : "Tema claro";
          document.querySelectorAll("[data-theme-text]").forEach((el) => (el.textContent = label));
          document.querySelectorAll("[data-theme-toggle]").forEach((btn) =>
            btn.setAttribute("aria-pressed", theme === "dark" ? "true" : "false")
          );
        };

        const toggles = document.querySelectorAll("[data-theme-toggle]");
        if (toggles.length) {
          toggles.forEach((btn) => {
            btn.addEventListener("click", () => {
              const current = root.getAttribute("data-bs-theme") === "dark" ? "dark" : "light";
              const next = current === "dark" ? "light" : "dark";
              applyTheme(next);
            });
          });
        }

        const initialTheme = root.getAttribute("data-bs-theme") === "dark" ? "dark" : "light";
        applyTheme(initialTheme);
      })();

      const scrollToBottom = (el) => {
        if (!el) return;
        el.scrollTop = el.scrollHeight;
      };

      document.body.addEventListener("htmx:afterSwap", (event) => {
        const target = event.detail?.target;
        const scrollables = [];

        if (target?.dataset?.autoscroll !== undefined) {
          scrollables.push(target);
        }

        target?.querySelectorAll?.("[data-autoscroll]").forEach((el) => scrollables.push(el));

        scrollables.forEach(scrollToBottom);
      });

      (() => {
        const bannerId = "pwa-install-banner";
        let deferredPrompt = null;

        const supportsInstallBanner = () => "Notification" in window && "serviceWorker" in navigator;
        const isStandaloneMode = () =>
          window.matchMedia("(display-mode: standalone)").matches || window.navigator.standalone === true;
        const isMobile = () => /Android|webOS|iPhone|iPad|iPod|BlackBerry|IEMobile|Opera Mini/i.test(navigator.userAgent);
        const manualInstructions = () =>
          isMobile()
            ? "Para receber notificações, abra o menu do navegador e use 'Adicionar à tela inicial'."
            : "Para receber notificações, abra o menu do navegador e escolha 'Instalar aplicativo'.";

        const ensureBanner = () => {
          let banner = document.getElementById(bannerId);
          if (banner) return banner;

          banner = document.createElement("div");
          banner.id = bannerId;
          banner.innerHTML = `
            <div class="wa-install-banner__inner">
              <div class="wa-install-banner__icon" aria-hidden="true">
                <i class="bi bi-phone"></i>
              </div>
              <div class="wa-install-banner__copy">
                <strong class="wa-install-banner__title">Instale o app se quiser notificações</strong>
                <span class="wa-install-banner__text" data-install-help></span>
              </div>
              <button type="button" class="wa-install-banner__btn" data-install-app></button>
            </div>
          `;

          banner.querySelector("[data-install-app]")?.addEventListener("click", async () => {
            const help = banner.querySelector("[data-install-help]");
            const button = banner.querySelector("[data-install-app]");
            if (!help) return;

            if (!deferredPrompt) {
              help.textContent = manualInstructions();
              return;
            }

            deferredPrompt.prompt();
            const choice = await deferredPrompt.userChoice;
            deferredPrompt = null;

            if (choice?.outcome === "accepted") {
              help.textContent = "Instalação iniciada. Abra o app instalado para ativar as notificações.";
            } else {
              help.textContent = manualInstructions();
              if (button) {
                button.innerHTML = '<i class="bi bi-info-circle"></i><span>Como instalar</span>';
              }
            }
          });

          document.body.prepend(banner);
          return banner;
        };

        const syncBanner = () => {
          const existingBanner = document.getElementById(bannerId);

          if (!supportsInstallBanner() || isStandaloneMode()) {
            existingBanner?.remove();
            return;
          }

          const banner = ensureBanner();
          const help = banner.querySelector("[data-install-help]");
          const button = banner.querySelector("[data-install-app]");
          if (!help || !button) return;

          if (deferredPrompt) {
            help.textContent = "Instale o app para ativar notificações neste dispositivo.";
            button.innerHTML = '<i class="bi bi-download"></i><span>Instalar app</span>';
            return;
          }

          help.textContent = manualInstructions();
          button.innerHTML = '<i class="bi bi-info-circle"></i><span>Como instalar</span>';
        };

        window.addEventListener("beforeinstallprompt", (event) => {
          event.preventDefault();
          deferredPrompt = event;
          syncBanner();
        });

        window.addEventListener("appinstalled", () => {
          deferredPrompt = null;
          document.getElementById(bannerId)?.remove();
        });

        window.addEventListener("focus", syncBanner);
        document.addEventListener("visibilitychange", () => {
          if (!document.hidden) syncBanner();
        });

        if (document.readyState === "loading") {
          document.addEventListener("DOMContentLoaded", syncBanner, { once: true });
        } else {
          syncBanner();
        }
      })();
    </script>

    <!-- Global Loading Overlay -->
    <div id="global-loader">
      <div class="loader-spinner"></div>
      <div class="fw-bold">Carregando...</div>
    </div>

    <script>
      // Global Loader Logic
      (() => {
        const loader = document.getElementById('global-loader');
        if (!loader) return;

        let requestCount = 0;

        const showLoader = () => {
          requestCount++;
          loader.classList.add('show');
        };

        const hideLoader = () => {
          requestCount = Math.max(0, requestCount - 1);
          if (requestCount === 0) {
            loader.classList.remove('show');
          }
        };

        // HTMX Requests
        document.body.addEventListener('htmx:beforeRequest', showLoader);
        document.body.addEventListener('htmx:afterRequest', hideLoader);
        document.body.addEventListener('htmx:onLoadError', hideLoader);
        document.body.addEventListener('htmx:sendError', hideLoader);

        // Standard Form Submissions (non-HTMX)
        document.addEventListener('submit', (e) => {
          const form = e.target;
          if (form.tagName === 'FORM' && !form.hasAttribute('hx-post') && !form.hasAttribute('hx-get') && !form.hasAttribute('hx-put') && !form.hasAttribute('hx-patch') && !form.hasAttribute('hx-delete')) {
            showLoader();
          }
        });

        // Navigation (Redirections/Link clicks)
        window.addEventListener('beforeunload', (e) => {
          showLoader();
        });

        // Handle case where user cancels navigation or it fails
        window.addEventListener('pageshow', (event) => {
          if (event.persisted) {
            hideLoader();
          }
          // Reset count on new page load
          requestCount = 0;
          loader.classList.remove('show');
        });
      })();
    </script>
