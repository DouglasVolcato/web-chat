{{- $version := default .cacheVersion "1" -}}
    <script src="{{ url "/js/bootstrap.bundle.min.js" }}?v={{ $version }}" defer></script>
    <script src="{{ url "/js/htmx.min.js" }}?v={{ $version }}" defer></script>
    <script>
      (() => {
        const storageKey = "template-theme";
        const root = document.documentElement;

        const applyTheme = (theme) => {
          root.setAttribute("data-bs-theme", theme);
          try {
            localStorage.setItem(storageKey, theme);
          } catch (error) {
            // ignore storage failures
          }

          const label = theme === "dark" ? "Tema escuro" : "Tema claro";
          document.querySelectorAll("[data-theme-text]").forEach((el) => (el.textContent = label));
          document.querySelectorAll("[data-theme-toggle]").forEach((btn) =>
            btn.setAttribute("aria-pressed", theme === "dark" ? "true" : "false")
          );
        };

        const toggles = document.querySelectorAll("[data-theme-toggle]");
        if (toggles.length) {
          toggles.forEach((btn) => {
            btn.addEventListener("click", () => {
              const current = root.getAttribute("data-bs-theme") === "dark" ? "dark" : "light";
              const next = current === "dark" ? "light" : "dark";
              applyTheme(next);
            });
          });
        }

        const initialTheme = root.getAttribute("data-bs-theme") === "dark" ? "dark" : "light";
        applyTheme(initialTheme);
      })();

      const scrollToBottom = (el) => {
        if (!el) return;
        el.scrollTop = el.scrollHeight;
      };

      document.body.addEventListener("htmx:afterSwap", (event) => {
        const target = event.detail?.target;
        const scrollables = [];

        if (target?.dataset?.autoscroll !== undefined) {
          scrollables.push(target);
        }

        target?.querySelectorAll?.("[data-autoscroll]").forEach((el) => scrollables.push(el));

        scrollables.forEach(scrollToBottom);
      });

      (() => {
        const bannerId = "pwa-install-banner";
        const modalId = "pwa-install-modal";
        let deferredPrompt = null;

        const supportsInstallBanner = () => "Notification" in window && "serviceWorker" in navigator;
        const isStandaloneMode = () =>
          window.matchMedia("(display-mode: standalone)").matches || window.navigator.standalone === true;
        const isAndroidMobile = () => /Android/i.test(navigator.userAgent);
        const isIOS = () =>
          /iPhone|iPad|iPod/i.test(navigator.userAgent) ||
          (navigator.platform === "MacIntel" && navigator.maxTouchPoints > 1);
        const hasAndroidInstallPrompt = () => isAndroidMobile() && deferredPrompt;

        const bannerCopy = () => {
          if (hasAndroidInstallPrompt()) {
            return {
              help: "Instale o app neste Android para ativar notificações.",
              button: '<i class="bi bi-download"></i><span>Instalar app</span>',
            };
          }

          if (isIOS()) {
            return {
              help: "No iPhone, instale pelo Safari para receber notificações.",
              button: '<i class="bi bi-info-circle"></i><span>Como instalar</span>',
            };
          }

          if (isAndroidMobile()) {
            return {
              help: "Se o botão de instalar não aparecer, veja o passo a passo do Android.",
              button: '<i class="bi bi-info-circle"></i><span>Como instalar</span>',
            };
          }

          return {
            help: "No computador, instale pelo menu do navegador para receber notificações.",
            button: '<i class="bi bi-info-circle"></i><span>Como instalar</span>',
          };
        };

        const installExperience = () => {
          if (hasAndroidInstallPrompt()) {
            return {
              title: "Instalar no Android",
              body: `
                <p class="mb-3">Instale o app neste Android para liberar notificações push neste dispositivo.</p>
                <ol class="wa-install-modal__steps">
                  <li>Toque no botão abaixo para abrir o instalador do navegador.</li>
                  <li>Confirme a instalação.</li>
                  <li>Abra o app instalado e então ative as notificações.</li>
                </ol>
              `,
              actionLabel: "Instalar app",
            };
          }

          if (isIOS()) {
            return {
              title: "Como instalar no iPhone",
              body: `
                <p class="mb-3">No iPhone, a instalação precisa ser feita pelo Safari.</p>
                <ol class="wa-install-modal__steps">
                  <li>Abra este site no Safari.</li>
                  <li>Toque no botão <strong>Compartilhar</strong>.</li>
                  <li>Escolha <strong>Adicionar à Tela de Início</strong>.</li>
                  <li>Confirme em <strong>Adicionar</strong> e abra o app instalado.</li>
                </ol>
              `,
            };
          }

          if (isAndroidMobile()) {
            return {
              title: "Como instalar no Android",
              body: `
                <p class="mb-3">Se o prompt automático não aparecer, instale manualmente pelo navegador.</p>
                <ol class="wa-install-modal__steps">
                  <li>Abra o menu do navegador.</li>
                  <li>Toque em <strong>Instalar app</strong> ou <strong>Adicionar à tela inicial</strong>.</li>
                  <li>Confirme a instalação e abra o app instalado.</li>
                </ol>
              `,
            };
          }

          return {
            title: "Como instalar no computador",
            body: `
              <p class="mb-3">No desktop, instale pelo menu do navegador para receber notificações.</p>
              <ol class="wa-install-modal__steps">
                <li>No Chrome ou Edge, abra o menu do navegador.</li>
                <li>Clique em <strong>Instalar aplicativo</strong> ou em <strong>Apps</strong>.</li>
                <li>Abra o app instalado e então ative as notificações.</li>
              </ol>
            `,
          };
        };

        const ensureModal = () => {
          let modal = document.getElementById(modalId);
          if (modal) return modal;

          modal = document.createElement("div");
          modal.id = modalId;
          modal.className = "modal fade";
          modal.tabIndex = -1;
          modal.setAttribute("aria-hidden", "true");
          modal.innerHTML = `
            <div class="modal-dialog modal-dialog-centered">
              <div class="modal-content border-0 shadow-lg">
                <div class="modal-header">
                  <h5 class="modal-title" data-install-modal-title></h5>
                  <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fechar"></button>
                </div>
                <div class="modal-body" data-install-modal-body></div>
                <div class="modal-footer">
                  <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Fechar</button>
                  <button type="button" class="btn btn-dark d-none" data-install-modal-action></button>
                </div>
              </div>
            </div>
          `;

          document.body.appendChild(modal);
          return modal;
        };

        const openInstallModal = () => {
          const modalEl = ensureModal();
          const titleEl = modalEl.querySelector("[data-install-modal-title]");
          const bodyEl = modalEl.querySelector("[data-install-modal-body]");
          const actionBtn = modalEl.querySelector("[data-install-modal-action]");
          const experience = installExperience();
          if (!titleEl || !bodyEl || !actionBtn) return;

          titleEl.textContent = experience.title;
          bodyEl.innerHTML = experience.body;

          if (experience.actionLabel) {
            actionBtn.classList.remove("d-none");
            actionBtn.textContent = experience.actionLabel;
            actionBtn.onclick = async () => {
              if (!deferredPrompt) return;

              const modal = window.bootstrap?.Modal.getInstance(modalEl);
              modal?.hide();

              deferredPrompt.prompt();
              const choice = await deferredPrompt.userChoice;
              deferredPrompt = null;

              const banner = document.getElementById(bannerId);
              const help = banner?.querySelector("[data-install-help]");
              if (choice?.outcome === "accepted" && help) {
                help.textContent = "Conclua a instalação e abra o app para ativar notificações.";
              } else {
                syncBanner();
              }
            };
          } else {
            actionBtn.classList.add("d-none");
            actionBtn.onclick = null;
            actionBtn.textContent = "";
          }

          const modal = window.bootstrap?.Modal.getOrCreateInstance(modalEl);
          modal?.show();
        };

        const ensureBanner = () => {
          let banner = document.getElementById(bannerId);
          if (banner) return banner;

          banner = document.createElement("div");
          banner.id = bannerId;
          banner.innerHTML = `
            <div class="wa-install-banner__inner">
              <div class="wa-install-banner__icon" aria-hidden="true">
                <i class="bi bi-phone"></i>
              </div>
              <div class="wa-install-banner__copy">
                <strong class="wa-install-banner__title">Instale o app se quiser notificações</strong>
                <span class="wa-install-banner__text" data-install-help></span>
              </div>
              <button type="button" class="wa-install-banner__btn" data-install-app></button>
            </div>
          `;

          banner.querySelector("[data-install-app]")?.addEventListener("click", openInstallModal);

          document.body.prepend(banner);
          return banner;
        };

        const syncBanner = () => {
          const existingBanner = document.getElementById(bannerId);

          if (!supportsInstallBanner() || isStandaloneMode()) {
            existingBanner?.remove();
            return;
          }

          const banner = ensureBanner();
          const help = banner.querySelector("[data-install-help]");
          const button = banner.querySelector("[data-install-app]");
          if (!help || !button) return;

          const copy = bannerCopy();
          help.textContent = copy.help;
          button.innerHTML = copy.button;
        };

        window.addEventListener("beforeinstallprompt", (event) => {
          event.preventDefault();
          deferredPrompt = event;
          syncBanner();
        });

        window.addEventListener("appinstalled", () => {
          deferredPrompt = null;
          document.getElementById(bannerId)?.remove();
        });

        window.addEventListener("focus", syncBanner);
        document.addEventListener("visibilitychange", () => {
          if (!document.hidden) syncBanner();
        });

        if (document.readyState === "loading") {
          document.addEventListener("DOMContentLoaded", syncBanner, { once: true });
        } else {
          syncBanner();
        }
      })();
    </script>

    <!-- Global Loading Overlay -->
    <div id="global-loader">
      <div class="loader-spinner"></div>
      <div class="fw-bold">Carregando...</div>
    </div>

    <script>
      // Global Loader Logic
      (() => {
        const loader = document.getElementById('global-loader');
        if (!loader) return;

        let requestCount = 0;

        const showLoader = () => {
          requestCount++;
          loader.classList.add('show');
        };

        const hideLoader = () => {
          requestCount = Math.max(0, requestCount - 1);
          if (requestCount === 0) {
            loader.classList.remove('show');
          }
        };

        // HTMX Requests
        document.body.addEventListener('htmx:beforeRequest', showLoader);
        document.body.addEventListener('htmx:afterRequest', hideLoader);
        document.body.addEventListener('htmx:onLoadError', hideLoader);
        document.body.addEventListener('htmx:sendError', hideLoader);

        // Standard Form Submissions (non-HTMX)
        document.addEventListener('submit', (e) => {
          const form = e.target;
          if (form.tagName === 'FORM' && !form.hasAttribute('hx-post') && !form.hasAttribute('hx-get') && !form.hasAttribute('hx-put') && !form.hasAttribute('hx-patch') && !form.hasAttribute('hx-delete')) {
            showLoader();
          }
        });

        // Navigation (Redirections/Link clicks)
        window.addEventListener('beforeunload', (e) => {
          showLoader();
        });

        // Handle case where user cancels navigation or it fails
        window.addEventListener('pageshow', (event) => {
          if (event.persisted) {
            hideLoader();
          }
          // Reset count on new page load
          requestCount = 0;
          loader.classList.remove('show');
        });
      })();
    </script>
