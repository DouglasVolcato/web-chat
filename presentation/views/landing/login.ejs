{{ template "head-landing.ejs" (dict "title" "Super Template - Login" "brand" "Super Template") }}
  <body class="bg-body-secondary">
    <main class="min-vh-100 d-flex align-items-center justify-content-center py-5">
      <div class="container">
        <div class="row justify-content-center">
          <div class="col-12 col-md-8 col-lg-5">
            <div class="card shadow-lg border-0">
              <div class="card-body p-4">
                <div class="text-center mb-4">
                  <img src="{{ url "/icons/logo.png" }}" alt="Logo" width="48" height="48" class="mb-2">
                  <h1 class="h4 fw-bold mb-1">Entrar no Web Chat Privado</h1>
                  <p class="text-secondary">Faça login para acessar sua área segura e somente após instalar o app (PWA).</p>
                </div>

                <div id="install-required" class="alert alert-warning" role="alert">
                  <strong>Instalação obrigatória:</strong> instale o app e abra por ele para liberar o login.
                  <div class="mt-2 d-flex flex-wrap gap-2 align-items-center">
                    <button id="install-app-btn" type="button" class="btn btn-sm btn-dark">Instalar app</button>
                    <span id="install-status" class="small text-secondary align-self-center">Verificando instalação…</span>
                  </div>
                </div>

                <div id="google-button-wrapper" class="d-flex justify-content-center mb-3 d-none">
                  <div id="google-btn"></div>
                </div>

                <form id="google-auth-form" hx-post="{{ url "/auth/google" }}" hx-target="#login-feedback" hx-swap="innerHTML">
                  <input type="hidden" name="credential" id="google-credential-input">
                </form>

                <div id="login-feedback" class="mt-3"></div>

                <div class="text-center mt-4">
                  <a href="{{ url "/" }}" class="text-decoration-none">Voltar para a landing page</a>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </main>

    <script src="https://accounts.google.com/gsi/client" async defer></script>
    <script>
      const googleContainer = document.getElementById("google-btn");
      const form = document.getElementById("google-auth-form");
      const credentialInput = document.getElementById("google-credential-input");
      const clientId = "{{ .GoogleClientID }}";
      const installBtn = document.getElementById("install-app-btn");
      const installRequired = document.getElementById("install-required");
      const installStatus = document.getElementById("install-status");
      const googleWrapper = document.getElementById("google-button-wrapper");

      let deferredPrompt = null;
      let googleInitialized = false;

      function isStandaloneMode() {
        const mql = window.matchMedia;
        if (!mql) return false;

        const standalone = mql("(display-mode: standalone)").matches;
        const fullscreen = mql("(display-mode: fullscreen)").matches;
        const minimalUi = mql("(display-mode: minimal-ui)").matches;
        const wco = mql("(display-mode: window-controls-overlay)").matches;
        const iosStandalone = window.navigator.standalone === true;
        const androidTWA = document.referrer.startsWith("android-app://");

        return standalone || fullscreen || minimalUi || wco || iosStandalone || androidTWA;
      }

      function setInstallBlocked(reason) {
        installRequired?.classList.remove("d-none");
        googleWrapper?.classList.add("d-none");

        if (!installStatus) return;

        if (reason === "no_prompt") {
          installStatus.textContent = "No celular: menu do navegador > 'Adicionar à tela inicial'. No desktop: menu > 'Instalar aplicativo'.";
          return;
        }

        installStatus.textContent = "Instale e abra pelo app para liberar o login.";
      }

      function setInstallAllowed() {
        installRequired?.classList.add("d-none");
        googleWrapper?.classList.remove("d-none");
        if (installStatus) {
          installStatus.textContent = "App instalado. Login liberado.";
        }
      }

      function refreshInstallGate() {
        if (isStandaloneMode()) {
          setInstallAllowed();
          return true;
        }

        setInstallBlocked(deferredPrompt ? "pending" : "no_prompt");
        return false;
      }

      function initGoogle() {
        if (googleInitialized) return;
        if (!refreshInstallGate()) return;
        if (!clientId) return;

        if (!window.google || !window.google.accounts || !window.google.accounts.id) {
          setTimeout(initGoogle, 300);
          return;
        }

        if (!googleContainer || !form || !credentialInput) {
          return;
        }

        googleInitialized = true;

        window.google.accounts.id.initialize({
          client_id: clientId,
          callback: (response) => {
            if (!refreshInstallGate()) {
              return;
            }
            credentialInput.value = response.credential;
            form.requestSubmit();
          },
        });

        window.google.accounts.id.renderButton(googleContainer, {
          theme: "outline",
          size: "large",
          width: "280",
        });

        window.google.accounts.id.prompt();
      }

      window.addEventListener("beforeinstallprompt", (event) => {
        event.preventDefault();
        deferredPrompt = event;

        if (!isStandaloneMode() && installStatus) {
          installStatus.textContent = "Pronto para instalar. Clique em 'Instalar app'.";
        }

        refreshInstallGate();
      });

      window.addEventListener("appinstalled", () => {
        deferredPrompt = null;
        setInstallAllowed();
        initGoogle();
      });

      installBtn?.addEventListener("click", async () => {
        if (isStandaloneMode()) {
          setInstallAllowed();
          initGoogle();
          return;
        }

        if (!deferredPrompt) {
          setInstallBlocked("no_prompt");
          return;
        }

        deferredPrompt.prompt();
        const choice = await deferredPrompt.userChoice;
        deferredPrompt = null;

        if (choice?.outcome === "accepted") {
          if (installStatus) installStatus.textContent = "Instalação confirmada. Abra o app instalado para continuar.";
        } else {
          if (installStatus) installStatus.textContent = "Instalação cancelada. O login continua bloqueado.";
        }

        refreshInstallGate();
      });

      window.addEventListener("focus", refreshInstallGate);
      document.addEventListener("visibilitychange", () => {
        if (!document.hidden) refreshInstallGate();
      });

      refreshInstallGate();
      initGoogle();
    </script>
  </body>
</html>
