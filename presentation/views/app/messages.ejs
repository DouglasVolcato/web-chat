{{ template "head.ejs" (dict "title" "Mensagens" "brand" "Web Chat") }}
<body class="bg-body d-flex flex-column min-vh-100">
{{ template "sidebar.ejs" (dict "currentPage" "messages" "user" .User) }}

<main class="app-main">
  <section class="container-fluid py-3 px-lg-4">
    <div class="messages-shell">
      <aside class="messages-sidebar">
        <div class="messages-sidebar-header">
          <h1 class="h5 mb-1">Conversas</h1>
          <p class="text-secondary small mb-0">Gerencie contatos no seu <a href="{{ url "/app/profile" }}">perfil</a>.</p>
        </div>

        <div class="messages-list" role="list">
          {{ range .Chats }}
          <a role="listitem" class="messages-chat-item {{ if eq .ChatID $.ActiveChatID }}active{{ end }}" href="{{ url (print "/app/messages/" .ChatID) }}">
            <div class="messages-chat-avatar">{{ if gt (len .ContactName) 0 }}{{ slice .ContactName 0 1 }}{{ else }}?{{ end }}</div>
            <div class="messages-chat-content">
              <div class="messages-chat-top">
                <strong class="messages-chat-name">{{ .ContactName }}</strong>
              </div>
              <p class="messages-chat-preview mb-0">{{ if .HasLastMessage }}{{ .LastMessage }}{{ else }}Sem mensagens ainda{{ end }}</p>
            </div>
          </a>
          {{ else }}
          <div class="p-3 text-secondary">Sem chats ativos. Adicione um contato pelo QR no perfil.</div>
          {{ end }}
        </div>
      </aside>

      <section class="messages-main">
        <header class="messages-main-header">
          <div>
            <h2 class="h6 mb-0">{{ if .Messages }}Conversa{{ else }}Selecione uma conversa{{ end }}</h2>
          </div>
          <button id="enable-push" class="btn btn-outline-secondary btn-sm" type="button">Ativar push</button>
        </header>

        <div class="messages-thread" id="messages-thread">
          {{ range .Messages }}
          <div class="message-row {{ if eq .SenderID $.User.ID }}outgoing{{ else }}incoming{{ end }}">
            <article class="message-bubble">
              <p class="mb-1">{{ .Content }}</p>
              <small class="message-author">{{ .SenderDisplay }}</small>
            </article>
          </div>
          {{ else }}
          <div class="empty-chat-state">
            <i class="bi bi-chat-square-text"></i>
            <p class="mb-0 text-secondary">Escolha um chat para iniciar a conversa.</p>
          </div>
          {{ end }}
        </div>

        {{ if .ActiveChatID }}
        <form method="post" action="{{ url "/app/messages/send" }}" class="messages-composer">
          <input type="hidden" name="csrf_token" value="{{ .CSRFToken }}">
          {{ range .Chats }}{{ if eq .ChatID $.ActiveChatID }}<input type="hidden" name="target_user_id" value="{{ .ContactUserID }}">{{ end }}{{ end }}
          <input class="form-control" maxlength="2000" type="text" name="content" placeholder="Digite sua mensagem" required>
          <button class="btn btn-success" type="submit"><i class="bi bi-send-fill"></i></button>
        </form>
        {{ else }}
        <div class="messages-composer disabled">
          <input class="form-control" type="text" placeholder="Selecione um chat para enviar mensagens" disabled>
          <button class="btn btn-success" type="button" disabled><i class="bi bi-send-fill"></i></button>
        </div>
        {{ end }}

        <small class="text-secondary px-3 pb-2" id="push-status">Permita notificações para receber mensagens.</small>
      </section>
    </div>
  </section>
</main>

<script>
  const threadEl = document.getElementById('messages-thread');
  if (threadEl) threadEl.scrollTop = threadEl.scrollHeight;

  async function enablePush() {
    const status = document.getElementById('push-status');
    if (!('serviceWorker' in navigator) || !('PushManager' in window)) {
      status.textContent = 'Push não suportado neste navegador.';
      return;
    }

    const vapidPublicKey = '{{ .VAPIDPublicKey }}';
    if (!vapidPublicKey) {
      status.textContent = 'Push ainda não configurado no servidor.';
      return;
    }

    const permission = await Notification.requestPermission();
    if (permission !== 'granted') {
      status.textContent = 'Permissão de notificação negada.';
      return;
    }

    const swUrl = '{{ url "/sw.js" }}';
    const swScopeBase = '{{ url "/" }}'.replace(/\/$/, '');
    const reg = await navigator.serviceWorker.register(swUrl, { scope: `${swScopeBase}/` });
    const sub = await reg.pushManager.subscribe({
      userVisibleOnly: true,
      applicationServerKey: Uint8Array.from(atob(vapidPublicKey.replace(/-/g, '+').replace(/_/g, '/')), c => c.charCodeAt(0))
    });

    const save = await fetch('{{ url "/app/push/subscriptions" }}', {
      method: 'POST',
      credentials: 'same-origin',
      headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': '{{ .CSRFToken }}' },
      body: JSON.stringify(sub)
    });

    status.textContent = save.ok ? 'Push ativado com sucesso.' : 'Falha ao salvar push.';
  }

  document.getElementById('enable-push')?.addEventListener('click', enablePush);
</script>
{{ template "scripts.ejs" . }}
</body>
</html>
