{{ template "head.ejs" (dict "title" "Mensagens" "brand" "Web Chat") }}
<body>
<div class="container-fluid py-3">
  <div class="row g-3">
    <div class="col-12 col-md-4">
      <div class="card h-100">
        <div class="card-body">
          <h1 class="h5">Chats</h1>

          <form id="qr-generate-form" class="mb-2" method="post" action="{{ url "/app/messages/contacts/qr" }}">
            <input type="hidden" name="csrf_token" value="{{ .CSRFToken }}">
            <button class="btn btn-outline-primary btn-sm" type="submit">Gerar QR de contato</button>
          </form>
          <div id="qr-result" class="small text-secondary mb-3"></div>

          <form class="mb-3" method="post" action="{{ url "/app/messages/contacts/qr/redeem" }}">
            <input type="hidden" name="csrf_token" value="{{ .CSRFToken }}">
            <input class="form-control form-control-sm mb-2" type="text" name="token" placeholder="Cole token QR" required>
            <button class="btn btn-primary btn-sm" type="submit">Adicionar contato</button>
          </form>

          {{ range .Chats }}
            <a class="d-block text-decoration-none border rounded p-2 mb-2" href="{{ url (print "/app/messages/" .ChatID) }}">
              <div class="fw-semibold">{{ .ContactName }}</div>
              {{ if .HasLastMessage }}<small class="text-secondary">{{ .LastMessage }}</small>{{ end }}
            </a>
          {{ else }}
            <p class="text-secondary">Sem chats ativos.</p>
          {{ end }}
        </div>
      </div>
    </div>

    <div class="col-12 col-md-8">
      <div class="card h-100">
        <div class="card-body d-flex flex-column" style="min-height: 65vh;">
          <h2 class="h6">Conversa</h2>
          <div class="flex-grow-1 overflow-auto border rounded p-2 mb-2">
            {{ range .Messages }}
              <div class="mb-2">
                <small class="text-secondary">{{ .SenderDisplay }}</small>
                <div>{{ .Content }}</div>
              </div>
            {{ else }}
              <p class="text-secondary">Selecione um chat e envie mensagens de texto.</p>
            {{ end }}
          </div>

          {{ if .ActiveChatID }}
          <form method="post" action="{{ url "/app/messages/send" }}" class="d-flex gap-2">
            <input type="hidden" name="csrf_token" value="{{ .CSRFToken }}">
            {{ range .Chats }}{{ if eq .ChatID $.ActiveChatID }}<input type="hidden" name="target_user_id" value="{{ .ContactUserID }}">{{ end }}{{ end }}
            <input class="form-control" maxlength="2000" type="text" name="content" placeholder="Digite sua mensagem" required>
            <button class="btn btn-success" type="submit">Enviar</button>
          </form>
          {{ end }}

          <hr>
          <div class="d-flex gap-2 align-items-center">
            <button id="enable-push" class="btn btn-outline-dark btn-sm" type="button">Ativar push</button>
            <small class="text-secondary" id="push-status">Permita notificações para receber mensagens.</small>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  const qrForm = document.getElementById('qr-generate-form');
  const qrResult = document.getElementById('qr-result');
  qrForm?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const data = new FormData(qrForm);
    const res = await fetch(qrForm.action, { method: 'POST', body: data, credentials: 'same-origin' });
    if (!res.ok) {
      qrResult.textContent = 'Falha ao gerar token QR.';
      return;
    }
    const payload = await res.json();
    qrResult.innerHTML = `<strong>Token:</strong> ${payload.token}<br><small>Expira em: ${new Date(payload.expires_at).toLocaleTimeString()}</small>`;
  });

  async function enablePush() {
    const status = document.getElementById('push-status');
    if (!('serviceWorker' in navigator) || !('PushManager' in window)) {
      status.textContent = 'Push não suportado neste navegador.';
      return;
    }

    const vapidPublicKey = '{{ .VAPIDPublicKey }}';
    if (!vapidPublicKey) {
      status.textContent = 'Push ainda não configurado no servidor.';
      return;
    }

    const permission = await Notification.requestPermission();
    if (permission !== 'granted') {
      status.textContent = 'Permissão de notificação negada.';
      return;
    }

    const reg = await navigator.serviceWorker.register('{{ url "/sw.js" }}');
    const sub = await reg.pushManager.subscribe({
      userVisibleOnly: true,
      applicationServerKey: Uint8Array.from(atob(vapidPublicKey.replace(/-/g, '+').replace(/_/g, '/')), c => c.charCodeAt(0))
    });

    const save = await fetch('{{ url "/app/push/subscriptions" }}', {
      method: 'POST',
      credentials: 'same-origin',
      headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': '{{ .CSRFToken }}' },
      body: JSON.stringify(sub)
    });

    status.textContent = save.ok ? 'Push ativado com sucesso.' : 'Falha ao salvar push.';
  }

  document.getElementById('enable-push')?.addEventListener('click', enablePush);
</script>
</body>
</html>
