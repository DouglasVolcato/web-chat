{{ template "head.ejs" (dict "title" "Web Chat - Mensagens" "brand" "Web Chat") }}
<body class="wa-body">

<div class="wa-app">
  <!-- Left Panel: Chat List -->
  <aside class="wa-sidebar" id="wa-sidebar">
    <header class="wa-sidebar-header">
      <div class="wa-sidebar-header-top">
        <div class="wa-user-info">
          <div class="wa-avatar wa-avatar--self">{{ if .User }}{{ slice .User.Name 0 1 }}{{ else }}U{{ end }}</div>
          <span class="wa-sidebar-title">Conversas</span>
        </div>
        <div class="wa-sidebar-actions">
          <a href="{{ url "/app/profile" }}" class="wa-icon-btn" title="Configurações" id="settings-btn">
            <i class="bi bi-gear"></i>
          </a>
        </div>
      </div>
      <div class="wa-search-bar">
        <i class="bi bi-search"></i>
        <input type="text" id="chat-search" class="wa-search-input" placeholder="Pesquisar ou começar uma nova conversa" autocomplete="off">
      </div>
    </header>

    <div class="wa-chat-list" id="chat-list" role="list">
      {{ range .Chats }}
      <a role="listitem" 
         class="wa-chat-item {{ if eq .ChatID $.ActiveChatID }}active{{ end }}" 
         href="{{ url (print "/app/messages/" .ChatID) }}"
         data-contact-name="{{ .ContactName }}">
        <div class="wa-avatar">{{ if gt (len .ContactName) 0 }}{{ slice .ContactName 0 1 }}{{ else }}?{{ end }}</div>
        <div class="wa-chat-item-content">
          <div class="wa-chat-item-top">
            <strong class="wa-chat-item-name">{{ .ContactName }}</strong>
            {{ if .HasLastMessage }}
            <span class="wa-chat-item-time">{{ .LastMessageAt.Format "15:04" }}</span>
            {{ end }}
          </div>
          <p class="wa-chat-item-preview">{{ if .HasLastMessage }}{{ .LastMessage }}{{ else }}<i class="bi bi-chat-dots"></i> Sem mensagens ainda{{ end }}</p>
        </div>
      </a>
      {{ else }}
      <div class="wa-empty-list">
        <div class="wa-empty-list-icon">
          <i class="bi bi-people"></i>
        </div>
        <p>Nenhum chat ativo</p>
        <a href="{{ url "/app/profile" }}#qr-section" class="wa-btn wa-btn--primary" style="margin-top: 1rem;">
          <i class="bi bi-person-plus-fill"></i> Adicionar contato
        </a>
      </div>
      {{ end }}
    </div>
  </aside>

  <!-- Right Panel: Active Chat or Welcome -->
  <main class="wa-main">
    {{ if .ActiveChatID }}
    <!-- Chat Header -->
    <header class="wa-chat-header">
      <button class="wa-icon-btn d-lg-none" type="button" id="back-to-list-btn">
        <i class="bi bi-arrow-left"></i>
      </button>
      <div class="wa-chat-header-info">
        {{ range .Chats }}{{ if eq .ChatID $.ActiveChatID }}
        <div class="wa-avatar wa-avatar--sm">{{ if gt (len .ContactName) 0 }}{{ slice .ContactName 0 1 }}{{ else }}?{{ end }}</div>
        <div>
          <h2 class="wa-chat-header-name">{{ .ContactName }}</h2>
        </div>
        {{ end }}{{ end }}
      </div>
      <div class="wa-chat-header-actions">
        <button class="wa-icon-btn" type="button" id="enable-push" title="Ativar notificações">
          <i class="bi bi-bell"></i>
        </button>
      </div>
    </header>

    <!-- Messages Thread -->
    <div class="wa-messages-thread" id="messages-thread">
      <div class="wa-messages-container">
        {{ range .Messages }}
        <div class="wa-msg {{ if eq .SenderUserID $.User.ID }}wa-msg--out{{ else }}wa-msg--in{{ end }}">
          <div class="wa-msg-bubble">
            <p class="wa-msg-text">{{ .Content }}</p>
          </div>
        </div>
        {{ end }}
      </div>
    </div>

    <!-- Composer -->
    <form method="post" action="{{ url "/app/messages/send" }}" class="wa-composer" id="message-form">
      <input type="hidden" name="csrf_token" value="{{ .CSRFToken }}">
      {{ range .Chats }}{{ if eq .ChatID $.ActiveChatID }}<input type="hidden" name="target_user_id" value="{{ .ContactUserID }}">{{ end }}{{ end }}
      <div class="wa-composer-inner">
        <input class="wa-composer-input" maxlength="2000" type="text" name="content" placeholder="" required autocomplete="off" id="message-input">
        <button class="wa-send-btn" type="submit" title="Enviar">
          <i class="bi bi-send-fill"></i>
        </button>
      </div>
    </form>

    <small class="wa-push-status" id="push-status"></small>

    {{ else }}
    <!-- Welcome Screen -->
    <div class="wa-welcome">
      <div class="wa-welcome-inner">
        <div class="wa-welcome-icon">
          <i class="bi bi-chat-square-heart"></i>
        </div>
        <h2 class="wa-welcome-title">Web Chat</h2>
        <p class="wa-welcome-text">Envie e receba mensagens com segurança.<br>Selecione uma conversa para começar.</p>
        <div class="wa-welcome-features">
          <div class="wa-welcome-feature">
            <i class="bi bi-shield-lock"></i>
            <span>Mensagens que expiram em 24h</span>
          </div>
          <div class="wa-welcome-feature">
            <i class="bi bi-qr-code"></i>
            <span>Conecte-se via QR Code</span>
          </div>
          <div class="wa-welcome-feature">
            <i class="bi bi-bell"></i>
            <span>Notificações push</span>
          </div>
        </div>
      </div>
    </div>
    {{ end }}
  </main>
</div>

<script>
  const activeChatID = "{{ .ActiveChatID }}";
  const currentUserID = "{{ if .User }}{{ .User.ID }}{{ end }}";
  const messagesBaseUrl = "{{ url "/app/messages" }}";
  const messageStateUrl = "{{ url "/app/messages/state" }}";
  const addContactUrl = "{{ url "/app/profile" }}#qr-section";
  const vapidPublicKey = '{{ .VAPIDPublicKey }}';
  const swUrl = '{{ url "/sw.js" }}';
  const swScopeBase = '{{ url "/" }}'.replace(/\/$/, '');
  const pushSubscriptionUrl = '{{ url "/app/push/subscriptions" }}';

  // Scroll to bottom of messages
  const threadEl = document.getElementById('messages-thread');
  const messagesContainer = threadEl?.querySelector('.wa-messages-container');
  const chatListEl = document.getElementById('chat-list');
  const pushStatus = document.getElementById('push-status');
  const root = document.documentElement;
  if (threadEl) threadEl.scrollTop = threadEl.scrollHeight;

  const escapeHTML = (value) => String(value || '')
    .replace(/&/g, '&amp;')
    .replace(/</g, '&lt;')
    .replace(/>/g, '&gt;')
    .replace(/"/g, '&quot;')
    .replace(/'/g, '&#39;');

  const formatTime = (value) => {
    if (!value) return '';
    const date = new Date(value);
    if (Number.isNaN(date.getTime())) return '';
    return date.toLocaleTimeString('pt-BR', { hour: '2-digit', minute: '2-digit' });
  };

  // Chat search filter
  const searchInput = document.getElementById('chat-search');
  const applyChatFilter = () => {
    const q = (searchInput?.value || '').toLowerCase();
    document.querySelectorAll('.wa-chat-item').forEach((item) => {
      const name = (item.dataset.contactName || '').toLowerCase();
      item.style.display = name.includes(q) ? '' : 'none';
    });
  };
  searchInput?.addEventListener('input', applyChatFilter);

  // Mobile sidebar toggle
  const sidebar = document.getElementById('wa-sidebar');
  document.getElementById('back-to-list-btn')?.addEventListener('click', () => sidebar?.classList.add('show'));
  const mobileMedia = window.matchMedia('(max-width: 991.98px)');
  const userAgent = String(navigator.userAgent || '');
  const isIOS = /iPhone|iPad|iPod/i.test(userAgent) || (navigator.platform === 'MacIntel' && navigator.maxTouchPoints > 1);
  const isStandalone = window.matchMedia('(display-mode: standalone)').matches || window.navigator.standalone === true;
  const shouldStabilizeIOSKeyboard = isIOS && isStandalone;

  if (shouldStabilizeIOSKeyboard) {
    document.body.classList.add('wa-ios-standalone-chat');
  }

  const syncViewportHeight = () => {
    const viewportHeight = window.visualViewport?.height || window.innerHeight;
    root.style.setProperty('--wa-viewport-height', `${Math.round(viewportHeight)}px`);
  };

  const syncSidebarForViewport = () => {
    if (!sidebar || !mobileMedia.matches) return;
    if (activeChatID) {
      sidebar.classList.remove('show');
      return;
    }
    sidebar.classList.add('show');
  };

  syncViewportHeight();
  syncSidebarForViewport();
  mobileMedia.addEventListener?.('change', syncSidebarForViewport);
  window.addEventListener('resize', syncViewportHeight);
  window.addEventListener('orientationchange', syncViewportHeight);
  window.visualViewport?.addEventListener('resize', syncViewportHeight);
  window.visualViewport?.addEventListener('scroll', syncViewportHeight);

  // Send with Enter
  const msgInput = document.getElementById('message-input');

  if (msgInput) {
    msgInput.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' && !e.shiftKey) {
        e.preventDefault();
        document.getElementById('message-form')?.requestSubmit();
      }
    });
    msgInput.addEventListener('focus', () => {
      window.setTimeout(() => {
        if (threadEl) threadEl.scrollTop = threadEl.scrollHeight;
      }, 150);
    });
    if (!mobileMedia.matches) {
      msgInput.focus();
    }
  }

  const keepConversationVisible = () => {
    syncViewportHeight();
    if (!msgInput || document.activeElement !== msgInput) return;
    window.setTimeout(() => {
      if (threadEl) threadEl.scrollTop = threadEl.scrollHeight;
    }, 120);
  };

  window.visualViewport?.addEventListener('resize', keepConversationVisible);

  const renderEmptyChatList = () => `
    <div class="wa-empty-list">
      <div class="wa-empty-list-icon">
        <i class="bi bi-people"></i>
      </div>
      <p>Nenhum chat ativo</p>
      <a href="${addContactUrl}" class="wa-btn wa-btn--primary" style="margin-top: 1rem;">
        <i class="bi bi-person-plus-fill"></i> Adicionar contato
      </a>
    </div>
  `;

  const renderChatList = (chats) => {
    if (!chatListEl) return;

    if (!Array.isArray(chats) || chats.length === 0) {
      chatListEl.innerHTML = renderEmptyChatList();
      return;
    }

    chatListEl.innerHTML = chats.map((chat) => {
      const isActive = chat.chat_id === activeChatID;
      const rawContactName = String(chat.contact_name || '?');
      const contactName = escapeHTML(rawContactName);
      const contactInitial = escapeHTML(rawContactName.trim().charAt(0) || '?');
      const preview = chat.has_last_message
        ? escapeHTML(chat.last_message || '')
        : '<i class="bi bi-chat-dots"></i> Sem mensagens ainda';
      const time = chat.has_last_message
        ? `<span class="wa-chat-item-time">${formatTime(chat.last_message_at)}</span>`
        : '';

      return `
        <a role="listitem"
           class="wa-chat-item ${isActive ? 'active' : ''}"
           href="${messagesBaseUrl}/${chat.chat_id}"
           data-contact-name="${contactName}">
          <div class="wa-avatar">${contactInitial}</div>
          <div class="wa-chat-item-content">
            <div class="wa-chat-item-top">
              <strong class="wa-chat-item-name">${contactName}</strong>
              ${time}
            </div>
            <p class="wa-chat-item-preview">${preview}</p>
          </div>
        </a>
      `;
    }).join('');

    applyChatFilter();
  };

  const renderMessages = (messages) => {
    if (!threadEl || !messagesContainer) return;

    const distanceFromBottom = threadEl.scrollHeight - threadEl.scrollTop - threadEl.clientHeight;
    const shouldStickToBottom = distanceFromBottom < 72;

    messagesContainer.innerHTML = (messages || []).map((message) => `
      <div class="wa-msg ${message.sender_user_id === currentUserID ? 'wa-msg--out' : 'wa-msg--in'}">
        <div class="wa-msg-bubble">
          <p class="wa-msg-text">${escapeHTML(message.content || '')}</p>
        </div>
      </div>
    `).join('');

    if (shouldStickToBottom) {
      threadEl.scrollTop = threadEl.scrollHeight;
      return;
    }

    threadEl.scrollTop = Math.max(0, threadEl.scrollHeight - threadEl.clientHeight - distanceFromBottom);
  };

  const chatsSignature = (chats) => JSON.stringify((chats || []).map((chat) => [
    chat.chat_id,
    chat.last_message,
    chat.last_message_at,
    chat.has_last_message,
  ]));

  const messagesSignature = (messages) => JSON.stringify((messages || []).map((message) => [
    message.id,
    message.content,
    message.created_at,
  ]));

  let lastChatState = '';
  let lastMessageState = '';
  let refreshingState = false;

  const refreshChatState = async () => {
    if (refreshingState || document.hidden) return;

    refreshingState = true;
    try {
      const url = new URL(messageStateUrl, window.location.origin);
      if (activeChatID) {
        url.searchParams.set('chat_id', activeChatID);
      }

      const response = await fetch(url.toString(), {
        credentials: 'same-origin',
        headers: {
          'Accept': 'application/json',
          'X-Requested-With': 'fetch'
        }
      });

      if (!response.ok) {
        return;
      }

      const payload = await response.json().catch(() => null);
      if (!payload) {
        return;
      }

      const nextChatState = chatsSignature(payload.chats);
      if (nextChatState !== lastChatState) {
        renderChatList(payload.chats || []);
        lastChatState = nextChatState;
      }

      if (activeChatID && messagesContainer) {
        const nextMessageState = messagesSignature(payload.messages);
        if (nextMessageState !== lastMessageState) {
          renderMessages(payload.messages || []);
          lastMessageState = nextMessageState;
        }
      }
    } finally {
      refreshingState = false;
    }
  };

  if (chatListEl) {
    window.setInterval(refreshChatState, 4000);
    window.addEventListener('focus', refreshChatState);
    document.addEventListener('visibilitychange', () => {
      if (!document.hidden) {
        refreshChatState();
      }
    });
    refreshChatState();
  }

  // Push notifications
  const setPushStatus = (message) => {
    if (!pushStatus) return;
    pushStatus.textContent = message || '';
  };

  const readTextResponse = async (response) => {
    const contentType = response.headers.get('content-type') || '';
    if (contentType.includes('application/json')) {
      const payload = await response.json().catch(() => null);
      if (payload?.message) return String(payload.message).trim();
    }
    return (await response.text().catch(() => '')).trim();
  };

  const base64UrlToUint8Array = (value) => {
    const normalized = value.replace(/-/g, '+').replace(/_/g, '/');
    const padded = normalized + '='.repeat((4 - normalized.length % 4) % 4);
    return Uint8Array.from(atob(padded), (char) => char.charCodeAt(0));
  };

  const detectPushDeviceLabel = () => {
    const ua = navigator.userAgent || '';
    const mode = window.matchMedia('(display-mode: standalone)').matches ? 'App' : 'Navegador';
    if (/Android/i.test(ua)) return `Android ${mode}`;
    if (/iPhone|iPad|iPod/i.test(ua)) return `iPhone ${mode}`;
    return `Desktop ${mode}`;
  };

  const registerPushWorker = async () => {
    if (typeof window.__webChatRegisterPWAWorker === 'function') {
      const registration = await window.__webChatRegisterPWAWorker();
      if (registration) return registration;
    }

    const registration = await navigator.serviceWorker.register(swUrl, {
      scope: `${swScopeBase}/`,
      updateViaCache: 'none'
    });
    await navigator.serviceWorker.ready;
    await registration.update().catch(() => {});
    return registration;
  };

  const persistSubscription = async (subscription) => {
    const payload = typeof subscription.toJSON === 'function' ? subscription.toJSON() : subscription;
    const response = await fetch(pushSubscriptionUrl, {
      method: 'POST',
      credentials: 'same-origin',
      headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': '{{ .CSRFToken }}' },
      body: JSON.stringify({
        ...payload,
        device_label: detectPushDeviceLabel()
      })
    });

    if (!response.ok) {
      throw new Error((await readTextResponse(response)) || 'Falha ao salvar as notificações.');
    }
  };

  const ensurePushSubscription = async ({ promptPermission = false, silent = false } = {}) => {
    if (!('serviceWorker' in navigator) || !('PushManager' in window)) {
      if (!silent) setPushStatus('Push não suportado neste navegador.');
      return null;
    }

    if (!vapidPublicKey) {
      if (!silent) setPushStatus('Push ainda não configurado.');
      return null;
    }

    let permission = Notification.permission;
    if (permission !== 'granted' && promptPermission) {
      permission = await Notification.requestPermission();
    }

    if (permission !== 'granted') {
      if (!silent) {
        setPushStatus(permission === 'denied' ? 'Permissão negada.' : 'Permita notificações no navegador.');
      }
      return null;
    }

    try {
      const registration = await registerPushWorker();
      let subscription = await registration.pushManager.getSubscription();

      if (!subscription) {
        subscription = await registration.pushManager.subscribe({
          userVisibleOnly: true,
          applicationServerKey: base64UrlToUint8Array(vapidPublicKey)
        });
      }

      await persistSubscription(subscription);
      if (!silent) setPushStatus('Notificações ativadas ✓');
      return subscription;
    } catch (error) {
      console.error('Push subscription error:', error);
      if (!silent) {
        setPushStatus(error?.message || 'Falha ao ativar notificações.');
      }
      return null;
    }
  };

  async function enablePush() {
    await ensurePushSubscription({ promptPermission: true, silent: false });
  }

  document.getElementById('enable-push')?.addEventListener('click', enablePush);

  if ('Notification' in window && Notification.permission === 'granted') {
    ensurePushSubscription({ silent: true });
    document.addEventListener('visibilitychange', () => {
      if (!document.hidden) {
        ensurePushSubscription({ silent: true });
      }
    });
  }
</script>
{{ template "scripts.ejs" . }}
</body>
</html>
