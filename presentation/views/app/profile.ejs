{{ template "head.ejs" (dict "title" "Web Chat - Configurações" "brand" "Web Chat") }}
<body class="wa-body">

<div class="wa-settings-wrapper">
  <!-- Header -->
  <header class="wa-settings-header">
    <a href="{{ url "/app/messages" }}" class="wa-icon-btn" title="Voltar">
      <i class="bi bi-arrow-left"></i>
    </a>
    <h1 class="wa-settings-title">Configurações</h1>
  </header>

  <div class="wa-settings-content">
    {{ if .Alert }}
    <div class="wa-alert wa-alert--{{ if eq (index .Alert "Type") "success" }}success{{ else }}danger{{ end }}">
      <i class="bi {{ if eq (index .Alert "Type") "success" }}bi-check-circle-fill{{ else }}bi-exclamation-triangle-fill{{ end }}"></i>
      <span>{{ index .Alert "Message" }}</span>
    </div>
    {{ end }}

    <!-- Profile Section -->
    <section class="wa-settings-section">
      <div class="wa-settings-profile-card">
        <div class="wa-avatar wa-avatar--lg">{{ if .Profile }}{{ slice .Profile.Name 0 1 }}{{ else }}U{{ end }}</div>
        <div class="wa-settings-profile-info">
          <h2 class="wa-settings-profile-name">{{ .Profile.Name }}</h2>
          <p class="wa-settings-profile-email">{{ .Profile.Email }}</p>
        </div>
      </div>
    </section>

    <!-- Edit Name -->
    <section class="wa-settings-section">
      <h3 class="wa-settings-section-title">
        <i class="bi bi-person-fill"></i>
        Dados do perfil
      </h3>
      <form method="post" action="{{ url "/app/profile/name" }}" class="wa-settings-form">
        <input type="hidden" name="csrf_token" value="{{ .CSRFToken }}">
        <div class="wa-form-group">
          <label for="profileName" class="wa-form-label">Nome</label>
          <input id="profileName" name="name" class="wa-form-input" type="text" required minlength="2" maxlength="60" value="{{ .Profile.Name }}" placeholder="Seu nome">
        </div>
        <div class="wa-form-group">
          <label class="wa-form-label">E-mail</label>
          <input class="wa-form-input wa-form-input--disabled" type="email" value="{{ .Profile.Email }}" disabled>
          <small class="wa-form-hint">O e-mail não pode ser alterado.</small>
        </div>
        <button class="wa-btn wa-btn--primary" type="submit">
          <i class="bi bi-check-lg"></i> Salvar nome
        </button>
      </form>
    </section>

    <!-- QR Code Section -->
    <section class="wa-settings-section" id="qr-section">
      <h3 class="wa-settings-section-title">
        <i class="bi bi-qr-code"></i>
        Contatos via QR Code
      </h3>
      <p class="wa-settings-section-desc">Gere seu QR Code para compartilhar com amigos ou use a câmera para ler o QR de outra pessoa.</p>

      <div class="wa-qr-actions">
        <button id="generate-qr-btn" class="wa-btn wa-btn--outline" type="button">
          <i class="bi bi-qr-code"></i> Gerar meu QR
        </button>
        <button id="start-scan-btn" class="wa-btn wa-btn--outline" type="button">
          <i class="bi bi-camera"></i> Ler QR Code
        </button>
      </div>

      <!-- Generated QR Panel -->
      <div id="qr-panel" class="wa-qr-panel d-none">
        <div class="wa-qr-image-wrapper">
          <canvas id="qr-canvas" width="280" height="280"></canvas>
        </div>
        <div class="wa-qr-info">
          <div class="wa-qr-token-row">
            <span class="wa-qr-label">Token:</span>
            <code id="qr-token-text" class="wa-qr-token"></code>
            <button type="button" class="wa-icon-btn wa-icon-btn--sm" id="copy-token-btn" title="Copiar token">
              <i class="bi bi-clipboard"></i>
            </button>
          </div>
          <div class="wa-qr-expiry">
            <i class="bi bi-clock"></i> Expira em: <span id="qr-expiry"></span>
          </div>
        </div>
      </div>

      <!-- Scanner Panel -->
      <div id="scan-panel" class="wa-scan-panel d-none">
        <div class="wa-scan-viewport" style="background: #000; border-radius: var(--sf-radius-md); overflow: hidden;">
          <div id="qr-reader" style="width: 100%; min-height: 250px;"></div>
        </div>
        <div class="wa-scan-controls" style="margin-top: 1rem;">
          <small id="scan-status" class="wa-scan-status">Posicione o QR Code dentro do quadro.</small>
          <button type="button" class="wa-btn wa-btn--ghost wa-btn--sm" id="stop-scan-btn">
            <i class="bi bi-x-lg"></i> Parar câmera
          </button>
        </div>
      </div>

      <!-- Manual token input -->
      <form id="redeem-form" method="post" action="{{ url "/app/messages/contacts/qr/redeem" }}" class="wa-token-form">
        <input type="hidden" name="csrf_token" value="{{ .CSRFToken }}">
        <label class="wa-form-label" for="qrTokenInput">Ou cole o token manualmente</label>
        <div class="wa-token-input-row">
          <input id="qrTokenInput" class="wa-form-input" type="text" name="token" placeholder="Cole o token do contato" required>
          <button class="wa-btn wa-btn--success" type="submit">
            <i class="bi bi-person-plus-fill"></i> Adicionar
          </button>
        </div>
      </form>
    </section>

    <!-- Danger Zone -->
    <section class="wa-settings-section wa-settings-section--danger">
      <h3 class="wa-settings-section-title wa-settings-section-title--danger">
        <i class="bi bi-exclamation-triangle-fill"></i>
        Zona de perigo
      </h3>
      <p class="wa-settings-section-desc">Essa ação é irreversível. Todos os seus dados, mensagens e contatos serão removidos permanentemente.</p>
      <form method="post" action="{{ url "/app/profile/delete" }}" class="wa-settings-form" id="delete-account-form">
        <input type="hidden" name="csrf_token" value="{{ .CSRFToken }}">
        <div class="wa-form-group">
          <label for="deleteConfirm" class="wa-form-label">Digite <code>EXCLUIR</code> para confirmar</label>
          <input id="deleteConfirm" name="confirm" class="wa-form-input wa-form-input--danger" type="text" autocomplete="off" required placeholder="EXCLUIR">
        </div>
        <button class="wa-btn wa-btn--danger" type="submit" id="delete-account-btn">
          <i class="bi bi-trash3"></i> Excluir minha conta
        </button>
      </form>
    </section>

    <!-- Logout -->
    <section class="wa-settings-section">
      <form method="post" action="{{ url "/logout" }}">
        <button class="wa-btn wa-btn--ghost wa-btn--full" type="submit">
          <i class="bi bi-box-arrow-right"></i> Sair da conta
        </button>
      </form>
      <div class="wa-settings-footer">
        {{ template "theme-toggle.ejs" (dict "ThemeButtonClasses" "wa-icon-btn" "ThemeLabelClasses" "wa-theme-label") }}
      </div>
    </section>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/qrcode@1.5.3/build/qrcode.min.js"></script>
<script src="https://unpkg.com/html5-qrcode" type="text/javascript"></script>
<script>
  // QR Code generation using qrcode.js
  function drawQRCode(canvas, data) {
    QRCode.toCanvas(canvas, data, {
      width: canvas.width,
      margin: 2,
      color: {
        dark: '#0f766e',
        light: '#ffffff'
      }
    }, function (error) {
      if (error) console.error(error);
    });
  }

  const qrPanel = document.getElementById('qr-panel');
  const qrCanvas = document.getElementById('qr-canvas');
  const qrTokenText = document.getElementById('qr-token-text');
  const qrExpiry = document.getElementById('qr-expiry');
  const tokenInput = document.getElementById('qrTokenInput');

  document.getElementById('generate-qr-btn')?.addEventListener('click', async () => {
    const btn = document.getElementById('generate-qr-btn');
    btn.disabled = true;
    btn.innerHTML = '<i class="bi bi-hourglass-split"></i> Gerando...';
    
    try {
      const fd = new FormData();
      fd.append('csrf_token', '{{ .CSRFToken }}');
      const res = await fetch('{{ url "/app/messages/contacts/qr" }}', { 
        method: 'POST', 
        headers: { 
          'X-CSRF-Token': '{{ .CSRFToken }}' 
        },
        body: fd, 
        credentials: 'same-origin' 
      });
      
      if (!res.ok) {
        const text = await res.text();
        throw new Error(text || 'Falha no servidor');
      }
      
      const payload = await res.json();
      if (!payload.token) throw new Error('Token não recebido');
      
      // Draw QR on canvas
      drawQRCode(qrCanvas, payload.token);
      
      qrTokenText.textContent = payload.token;
      qrExpiry.textContent = new Date(payload.expires_at).toLocaleTimeString('pt-BR');
      qrPanel.classList.remove('d-none');
      
      // Scroll to QR panel
      qrPanel.scrollIntoView({ behavior: 'smooth', block: 'center' });
    } catch(e) {
      console.error(e);
      alert('Erro ao gerar QR Code: ' + e.message);
    } finally {
      btn.disabled = false;
      btn.innerHTML = '<i class="bi bi-qr-code"></i> Gerar meu QR';
    }
  });

  // Copy token
  document.getElementById('copy-token-btn')?.addEventListener('click', () => {
    const token = qrTokenText.textContent;
    navigator.clipboard.writeText(token).then(() => {
      const btn = document.getElementById('copy-token-btn');
      btn.innerHTML = '<i class="bi bi-check-lg"></i>';
      setTimeout(() => { btn.innerHTML = '<i class="bi bi-clipboard"></i>'; }, 2000);
    });
  });

  // QR Scanner
  let html5QrCode;

  async function startScanner() {
    const scanPanel = document.getElementById('scan-panel');
    const status = document.getElementById('scan-status');
    scanPanel.classList.remove('d-none');
    
    // Scroll to scan panel so user sees the camera
    scanPanel.scrollIntoView({ behavior: 'smooth', block: 'center' });
    
    if (!html5QrCode) {
      html5QrCode = new Html5Qrcode("qr-reader");
    }

    try {
      status.textContent = 'Apontando para o QR Code...';
      status.classList.remove('wa-scan-status--error');
      
      await html5QrCode.start(
        { facingMode: "environment" },
        { fps: 10, qrbox: { width: 200, height: 200 } },
        (decodedText, decodedResult) => {
          // Success
          tokenInput.value = decodedText;
          status.textContent = '✓ QR Code lido com sucesso!';
          status.classList.add('wa-scan-status--success');
          stopScanner();
          // Auto-focus the add button
          tokenInput.scrollIntoView({ behavior: 'smooth', block: 'center' });
        },
        (errorMessage) => {
          // Parse error, ignore to keep scanning
        }
      );
    } catch (err) {
      status.textContent = 'Não foi possível acessar a câmera. Verifique as permissões.';
      status.classList.add('wa-scan-status--error');
    }
  }

  function stopScanner() {
    if (html5QrCode && html5QrCode.isScanning) {
      html5QrCode.stop().then(ignore => {}).catch(err => {});
    }
  }

  window.addEventListener('beforeunload', stopScanner);
  document.getElementById('start-scan-btn')?.addEventListener('click', startScanner);
  document.getElementById('stop-scan-btn')?.addEventListener('click', () => {
    stopScanner();
    document.getElementById('scan-panel')?.classList.add('d-none');
  });

  // Delete account confirmation
  document.getElementById('delete-account-form')?.addEventListener('submit', (e) => {
    const confirm = document.getElementById('deleteConfirm')?.value?.trim();
    if (confirm !== 'EXCLUIR') {
      e.preventDefault();
      alert('Digite EXCLUIR para confirmar.');
    }
  });
</script>

{{ template "scripts.ejs" . }}
</body>
</html>
