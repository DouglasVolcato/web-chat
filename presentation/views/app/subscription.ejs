{{ template "head.ejs" (dict "title" "SUPER TEMPLATE - Assinatura") }}
{{ $subscription := .ActiveSubscription }}
{{ $history := .PaymentHistory }}
<body class="bg-body d-flex flex-column min-vh-100">
{{ template "sidebar.ejs" (dict "currentPage" "subscription" "user" .User) }}

<main class="app-main">
    <div class="container-xxl py-4 flex-grow-1">
      <div class="page-hero mb-4 p-4 d-flex flex-wrap justify-content-between align-items-center gap-3 rounded-4 bg-body-tertiary shadow-sm">
        <div class="d-flex align-items-center gap-3">
          <div class="bg-warning-subtle text-warning rounded-circle d-flex align-items-center justify-content-center" style="width: 48px; height: 48px; background: rgba(255, 193, 7, 0.1); color: #ffc107;">
            <i class="bi bi-bag-check fs-5"></i>
          </div>
          <div class="d-flex flex-column gap-0">
            <p class="text-warning text-uppercase fw-semibold small mb-0">Gestão de Conta</p>
            <h1 class="fw-bold mb-0">Assinatura Premium</h1>
            <p class="text-muted mb-0 small">Acompanhe seu plano, histórico de pagamentos e benefícios ativos.</p>
          </div>
        </div>
        <div class="d-flex align-items-center gap-2 flex-wrap">
          {{ if and .TrialActive (not .SubscriptionPaid) }}
            <span class="badge bg-info-subtle text-info px-3 py-2 rounded-pill small">Teste grátis até {{ .TrialEndsAt.Format "02/01/2006" }}</span>
          {{ end }}
          {{ if $subscription }}
            <span class="badge bg-primary-subtle text-primary px-3 py-2 rounded-pill small">
              {{ if eq $subscription.Cycle "MONTHLY" }}Mensal{{ else if eq $subscription.Cycle "YEARLY" }}Anual{{ else }}{{ $subscription.Cycle }}{{ end }}
            </span>
            <span class="badge {{ if .SubscriptionPaid }}bg-success-subtle text-success{{ else }}bg-warning-subtle text-warning{{ end }} px-3 py-2 rounded-pill small">
              {{ if .SubscriptionPaid }}Ativa{{ else }}Pagamento pendente{{ end }}
            </span>
          {{ else if and (not .TrialActive) (not .SubscriptionPaid) }}
            <span class="badge bg-warning-subtle text-warning px-3 py-2 rounded-pill small">Sem assinatura ativa</span>
          {{ end }}
        </div>
      </div>

    {{ if .AccessReason }}
        <div class="alert alert-success border-0 shadow-sm d-flex align-items-start gap-2 mb-4">
            <i class="bi bi-patch-check fs-4 text-success"></i>
            <div>
                <p class="fw-semibold mb-0">Acesso especial</p>
                <small class="text-muted">{{ .AccessReason }}</small>
            </div>
        </div>
    {{ end }}

{{ if and .TrialActive (not .SubscriptionPaid) }}
    <div class="alert alert-info border-0 shadow-sm d-flex align-items-center gap-2 rounded-4">
            <i class="bi bi-hourglass-split"></i>
            <div>
                <p class="fw-semibold mb-0">Teste grátis ativo</p>
                <small class="text-muted">Seu período gratuito vai até {{ .TrialEndsAt.Format "02/01/2006" }}.</small>
            </div>
        </div>
    {{ end }}

    {{ if .ShowCompactSubscription }}
        <div class="card-premium p-5 text-center shadow-sm border-0 bg-body-tertiary">
            <span class="badge bg-warning-subtle text-warning rounded-pill px-3 py-2 mb-3">Teste grátis encerrado</span>
            <h2 class="fw-bold mb-2">Hora de assinar o Super Template</h2>
            <p class="text-muted mb-4">Seu período gratuito terminou em {{ .TrialEndsAt.Format "02/01/2006" }}. Assine agora e desbloqueie todos os módulos.</p>
            <a href="{{ url "/app/billing" }}" class="btn btn-premium btn-lg px-5">Assinar agora</a>
        </div>
    {{ else }}
    <div class="row g-4 align-items-stretch">
        <div class="col-12 col-lg-7">
            <div class="card shadow-sm border-0 rounded-4 h-100">
                <div class="card-body p-4">
                    <div id="subscriptionFeedback"></div>
                    <div class="d-flex justify-content-between align-items-start flex-wrap gap-3 mb-3">
                        <div>
                            <p class="text-uppercase small fw-semibold text-muted mb-1">Status</p>
                            <h4 class="fw-bold mb-0">
                                {{ if and .TrialActive (not .SubscriptionPaid) }}
                                    Teste grátis ativo
                                {{ else if $subscription }}
                                    {{ if .SubscriptionPaid }}Assinatura ativa{{ else }}Pagamento pendente{{ end }}
                                {{ else }}
                                    Assinatura ausente
                                {{ end }}
                            </h4>
                            <p class="text-muted mb-0">
                                {{ if and .TrialActive (not .SubscriptionPaid) }}
                                    Seu teste gratuito termina em {{ .TrialEndsAt.Format "02/01/2006" }}.
                                {{ else if $subscription }}
                                    {{ $subscription.Description }}
                                {{ else }}
                                    Finalize uma assinatura para liberar todos os módulos Premium.
                                {{ end }}
                            </p>
                        </div>
                        <div class="text-end">
                            {{ if and .TrialActive (not .SubscriptionPaid) (not $subscription) }}
                                <span class="badge bg-info-subtle text-info mt-2">Teste grátis 7 dias</span>
                            {{ else }}
                                <span class="badge bg-info-subtle text-info mt-2">
                                    Ciclo {{ if $subscription }}{{ if eq $subscription.Cycle "MONTHLY" }}Mensal{{ else if eq $subscription.Cycle "YEARLY" }}Anual{{ else }}{{ $subscription.Cycle }}{{ end }}{{ else }}indefinido{{ end }}
                                </span>
                            {{ end }}
                        </div>
                    </div>
                    {{ if $subscription }}
                        <div class="row g-3 mb-4">
                            <div class="col-12 col-sm-6">
                                <div class="p-3 border rounded-3 bg-body-tertiary h-100">
                                    <p class="text-muted small mb-1">Valor</p>
                                    <h5 class="fw-bold mb-0">R${{ printf "%.2f" $subscription.Value }}</h5>
                                    <p class="text-muted small mb-0">Cobrança recorrente via Asaas.</p>
                                </div>
                            </div>
                            <div class="col-12 col-sm-6">
                                <div class="p-3 border rounded-3 bg-body-tertiary h-100 d-flex flex-column justify-content-center">
                                    <p class="text-muted small mb-1">Frequência</p>
                                    <h6 class="fw-semibold mb-0">
                                        {{ if eq $subscription.Cycle "MONTHLY" }}Pagamento Mensal{{ else if eq $subscription.Cycle "YEARLY" }}Pagamento Anual{{ else }}{{ $subscription.Cycle }}{{ end }}
                                    </h6>
                                </div>
                            </div>
                        </div>
                    {{ end }}
                    <div class="d-flex flex-wrap gap-2">
                        {{ if not $subscription }}
                            <a href="{{ url "/app/billing" }}" class="btn btn-primary px-4 fw-bold">Assinar Agora</a>
                        {{ end }}
                        {{ if $subscription }}
                            <form hx-post="{{ url "/app/subscription/cancel" }}" hx-target="#subscriptionFeedback" hx-swap="innerHTML" hx-confirm="Tem certeza que deseja cancelar sua assinatura?" class="m-0 d-inline">
                                <button type="submit" class="btn btn-outline-danger px-4 fw-bold">Cancelar assinatura</button>
                            </form>
                        {{ end }}
                        <a class="btn btn-outline-secondary px-4" href="mailto:volcatosistemas@gmail.com" target="_blank" rel="noopener">Suporte de cobrança</a>
                        <a class="btn btn-outline-primary px-4" href="mailto:volcatosistemas@gmail.com" target="_blank" rel="noopener">Contato</a>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-12 col-lg-5">
            <div class="card shadow-sm border-0 rounded-4 mb-4 h-100">
                <div class="card-body p-4">
                    <p class="text-uppercase small fw-semibold text-muted mb-1">Resumo rápido</p>
                    <div class="d-flex flex-column gap-3">
                        <div class="d-flex align-items-center justify-content-between p-3 bg-body-tertiary rounded-3 border">
                            <div>
                                <p class="text-muted mb-1 small">Cobranças registradas</p>
                                <h5 class="fw-bold mb-0">{{ len $history }} cobranças</h5>
                            </div>
                            <span class="badge bg-primary-subtle text-primary">Histórico</span>
                        </div>
                        <div class="d-flex align-items-center justify-content-between p-3 bg-body-tertiary rounded-3 border">
                            <div>
                                <p class="text-muted mb-1 small">Plano Atual</p>
                                <h6 class="fw-semibold mb-0">
                                    {{ if $subscription }}
                                        {{ if eq $subscription.Cycle "MONTHLY" }}Mensal Premium{{ else if eq $subscription.Cycle "YEARLY" }}Anual Premium{{ else }}{{ $subscription.Cycle }}{{ end }}
                                    {{ else if and .TrialActive (not .SubscriptionPaid) }}
                                        Teste gratuito
                                    {{ else }}
                                        Nenhum plano ativo
                                    {{ end }}
                                </h6>
                            </div>
                            <span class="badge bg-success-subtle text-success">Atendimento</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4 mt-1 align-items-stretch">
        <div class="col-12">
            <div class="card shadow-sm border-0 rounded-4 h-100">
                <div class="card-header bg-transparent border-0 px-4 pt-4 pb-0 d-flex justify-content-between align-items-center">
                    <div>
                        <h2 class="h5 mb-0">Histórico de pagamentos</h2>
                        <p class="text-muted small mb-0">Notas fiscais e links de pagamento gerados automaticamente.</p>
                    </div>
                    <span class="badge bg-primary-subtle text-primary">Conta Verificada</span>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive rounded-3 border m-4 mt-3">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th class="fw-semibold">Vencimento</th>
                                    <th class="fw-semibold">Descrição</th>
                                    <th class="fw-semibold">Valor</th>
                                    <th class="fw-semibold">Status</th>
                                    <th class="fw-semibold text-end">Ação</th>
                                </tr>
                            </thead>
                            <tbody>
                                {{ if gt (len $history) 0 }}
                                    {{ range $history }}
                                        <tr>
                                            <td>{{ if .DueDate.Valid }}{{ .DueDate.Time.Format "02/01/2006" }}{{ else }}--{{ end }}</td>
                                            <td>{{ .Description }}</td>
                                            <td>R${{ printf "%.2f" .Value }}</td>
                                            <td>
                                                {{ if or (eq .Status "RECEIVED") (eq .Status "CONFIRMED") (eq .Status "RECEIVED_IN_CASH") }}
                                                    <span class="badge bg-success">Pago</span>
                                                {{ else if eq .Status "PENDING" }}
                                                    <span class="badge bg-warning-subtle text-warning">Pendente</span>
                                                {{ else if eq .Status "OVERDUE" }}
                                                    <span class="badge bg-danger-subtle text-danger">Vencido</span>
                                                {{ else }}
                                                    <span class="badge bg-secondary-subtle text-secondary">{{ .Status }}</span>
                                                {{ end }}
                                            </td>
                                            <td class="text-end">
                                                {{ if or (eq .Status "RECEIVED") (eq .Status "CONFIRMED") (eq .Status "RECEIVED_IN_CASH") }}
                                                    {{ if .ReceiptURL }}
                                                        <a href="{{ .ReceiptURL }}" target="_blank" class="btn btn-sm btn-outline-success fw-bold">
                                                            <i class="bi bi-file-earmark-check me-1"></i>Recibo
                                                        </a>
                                                    {{ else }}
                                                        <span class="text-muted small"></span>
                                                    {{ end }}
                                                {{ else }}
                                                    {{ if .PaymentLink.Valid }}
                                                        <a href="{{ .PaymentLink.String }}" target="_blank" class="btn btn-sm btn-primary fw-bold">Pagar fatura</a>
                                                    {{ else if .InvoiceURL }}
                                                        <a href="{{ .InvoiceURL }}" target="_blank" class="btn btn-sm btn-primary fw-bold">Pagar fatura</a>
                                                    {{ else }}
                                                        <span class="text-muted small">Aguardando link</span>
                                                    {{ end }}
                                                {{ end }}
                                            </td>
                                        </tr>
                                    {{ end }}
                                {{ else }}
                                    <tr>
                                        <td colspan="5" class="text-center py-4 text-muted">Nenhuma cobrança encontrada.</td>
                                    </tr>
                                {{ end }}
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
    {{ end }}
    </div>
</main>

{{ template "footer.ejs" (dict "brand" "SUPER TEMPLATE" "appFooter" true) }}
{{ template "scripts.ejs" . }}
