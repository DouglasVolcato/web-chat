{{ template "head.ejs" (dict "title" "Web Chat - Novo Chat" "brand" "Web Chat") }}
<body class="wa-body">

<div class="wa-settings-wrapper">
  <!-- Header -->
  <header class="wa-settings-header">
    <a href="{{ url "/app/chat" }}" class="wa-icon-btn" title="Voltar">
      <i class="bi bi-arrow-left"></i>
    </a>
    <h1 class="wa-settings-title">Novo chat com IA</h1>
  </header>

  <div class="wa-settings-content">
    <!-- Illustration -->
    <section class="wa-settings-section" style="text-align: center; padding: 2rem 1.25rem 1rem;">
      <div class="wa-avatar wa-avatar--lg wa-avatar--ai" style="margin: 0 auto 1rem;">
        <i class="bi bi-robot"></i>
      </div>
      <p class="wa-settings-section-desc" style="max-width: 360px; margin: 0 auto;">
        Crie um novo chat com a IA. Defina um título e um contexto para obter respostas mais relevantes.
      </p>
    </section>

    <!-- Form -->
    <section class="wa-settings-section">
      <h3 class="wa-settings-section-title">
        <i class="bi bi-pencil-square"></i>
        Detalhes do chat
      </h3>
      <form class="wa-settings-form" method="post" action="{{ url "/app/chat" }}" data-overlay-submit>
        <div class="wa-form-group">
          <label class="wa-form-label" for="chatTitle">Título</label>
          <input class="wa-form-input" id="chatTitle" name="title" placeholder="Ex: Onboarding do cliente" required autofocus>
        </div>
        <div class="wa-form-group">
          <label class="wa-form-label" for="chatContext">Contexto (opcional)</label>
          <textarea class="wa-form-input wa-form-textarea" id="chatContext" name="context" rows="4" placeholder="Descreva o contexto ou objetivo da conversa para a IA responder melhor..."></textarea>
          <small class="wa-form-hint">O contexto ajuda a IA a entender melhor suas perguntas.</small>
        </div>
        <div class="wa-form-actions">
          <a href="{{ url "/app/chat" }}" class="wa-btn wa-btn--ghost">Cancelar</a>
          <button class="wa-btn wa-btn--primary" type="submit">
            <i class="bi bi-plus-lg"></i> Criar chat
          </button>
        </div>
      </form>
    </section>
  </div>
</div>

{{ template "scripts.ejs" . }}
</body>
</html>
