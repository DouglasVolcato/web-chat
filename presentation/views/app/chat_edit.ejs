{{ template "head.ejs" (dict "title" "Web Chat - Editar Chat" "brand" "Web Chat") }}
<body class="wa-body">

<div class="wa-settings-wrapper">
  <!-- Header -->
  <header class="wa-settings-header">
    <a href='{{ url (printf "/app/chat/%s" .Chat.ID) }}' class="wa-icon-btn" title="Voltar">
      <i class="bi bi-arrow-left"></i>
    </a>
    <h1 class="wa-settings-title">Editar chat</h1>
  </header>

  <div class="wa-settings-content">
    <!-- Current Chat Info -->
    <section class="wa-settings-section">
      <div class="wa-settings-profile-card">
        <div class="wa-avatar wa-avatar--lg wa-avatar--ai">
          <i class="bi bi-robot"></i>
        </div>
        <div class="wa-settings-profile-info">
          <h2 class="wa-settings-profile-name">{{ default .Chat.Title "Chat" }}</h2>
          <p class="wa-settings-profile-email">
            {{ if .Chat.Context }}{{ .Chat.Context }}{{ else }}Sem contexto definido{{ end }}
          </p>
        </div>
      </div>
    </section>

    <!-- Form -->
    <section class="wa-settings-section">
      <h3 class="wa-settings-section-title">
        <i class="bi bi-pencil-fill"></i>
        Atualizar informações
      </h3>
      <form class="wa-settings-form" method="post" action='{{ url (printf "/app/chat/%s/edit" .Chat.ID) }}' data-overlay-submit>
        <div class="wa-form-group">
          <label class="wa-form-label" for="chatTitle">Título</label>
          <input class="wa-form-input" id="chatTitle" name="title" type="text" value="{{ default .Chat.Title "Chat" }}" required autofocus>
        </div>
        <div class="wa-form-group">
          <label class="wa-form-label" for="chatContext">Contexto</label>
          <textarea class="wa-form-input wa-form-textarea" id="chatContext" name="context" rows="4" placeholder="Descreva o contexto ou objetivo da conversa...">{{ default .Chat.Context "" }}</textarea>
          <small class="wa-form-hint">O contexto ajuda a IA a entender melhor suas perguntas.</small>
        </div>
        <div class="wa-form-actions">
          <a href='{{ url (printf "/app/chat/%s" .Chat.ID) }}' class="wa-btn wa-btn--ghost">Cancelar</a>
          <button class="wa-btn wa-btn--primary" type="submit">
            <i class="bi bi-check-lg"></i> Salvar alterações
          </button>
        </div>
      </form>
    </section>

    <!-- Danger Zone -->
    <section class="wa-settings-section wa-settings-section--danger">
      <h3 class="wa-settings-section-title wa-settings-section-title--danger">
        <i class="bi bi-exclamation-triangle-fill"></i>
        Remover chat
      </h3>
      <p class="wa-settings-section-desc">Essa ação é irreversível. Todas as mensagens deste chat serão perdidas.</p>
      <button class="wa-btn wa-btn--danger"
              hx-delete='{{ url (printf "/app/chat/%s" .Chat.ID) }}'
              hx-target="body" hx-swap="none"
              hx-confirm="Deseja remover este chat permanentemente?">
        <i class="bi bi-trash3"></i> Remover este chat
      </button>
    </section>
  </div>
</div>

{{ template "scripts.ejs" . }}
</body>
</html>
