{{ template "head.ejs" (dict "title" "Super Template - Editar Chat" "brand" "Super Template") }}

<body class="bg-body d-flex flex-column min-vh-100">
  {{ template "sidebar.ejs" (dict "currentPage" "chat" "user" .User) }}

  <main class="app-main">
    <div class="container-xl py-4">
      <div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-4">
        <div>
          <h1 class="fw-bold mb-1">Editar chat</h1>
          <p class="text-secondary mb-0">Atualize o título ou o contexto.</p>
        </div>
        <a class="btn btn-outline-secondary" href="/app/chat/{{ .Chat.ID }}">Voltar</a>
      </div>

      <div class="card border-0 shadow-sm">
        <div class="card-body">
          <form class="d-flex flex-column gap-3" method="post" action="/app/chat/{{ .Chat.ID }}/edit" data-overlay-submit>
            <div>
              <label class="form-label fw-semibold" for="chatTitle">Título</label>
              <input type="text" class="form-control" id="chatTitle" name="title" value="{{ default .Chat.Title "Chat" }}" required>
            </div>
            <div>
              <label class="form-label fw-semibold" for="chatContext">Contexto</label>
              <textarea class="form-control" id="chatContext" name="context" rows="4">{{ default .Chat.Context "" }}</textarea>
            </div>
            <div class="d-flex justify-content-end gap-2">
              <a class="btn btn-light" href="/app/chat/{{ .Chat.ID }}">Cancelar</a>
              <button class="btn btn-primary" type="submit">Salvar</button>
            </div>
          </form>
        </div>
      </div>
    </div>
  </main>

  {{ template "scripts.ejs" . }}
</body>
</html>
